// Tu Turno Pro — Complete Database Schema
// Multi-tenant SaaS for Sports Complex Management

datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

// ============================================
// TENANT & AUTH
// ============================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  phone     String?
  logo      String?
  modules   String[] @default(["reservations"]) // reservations, inventory, reports, pos, tournaments, school, events
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Subscription
  plan       String    @default("starter") // free, starter, pro, enterprise
  planStatus String    @default("active") // active, past_due, cancelled
  planExpiry DateTime?

  users             User[]
  complexes         Complex[]
  products          Product[]
  categories        Category[]
  sales             Sale[]
  cashSessions      CashSession[]
  suppliers         Supplier[]
  customers         Customer[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  events            Event[]
  tournaments       Tournament[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  hashedPassword String
  role           String   @default("staff") // super_admin, admin, staff
  phone          String?
  modules        String[] @default([]) // Per-user module visibility (empty = default for role)
  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  complexId      String?
  complex        Complex? @relation("StaffMembers", fields: [complexId], references: [id])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reservations      Reservation[]
  cashSessionsOpen  CashSession[] @relation("OpenedBy")
  cashSessionsClose CashSession[] @relation("ClosedBy")
}

// ============================================
// COMPLEX & COURTS
// ============================================

model Complex {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  address     String?
  phone       String?
  openingTime String   @default("08:00")
  closingTime String   @default("23:00")
  sportTypes  String[] @default(["futbol"]) // futbol, padel, tenis
  isActive    Boolean  @default(true)

  // Deposit settings
  requiresDeposit    Boolean  @default(false)
  depositAmount      Decimal? @db.Decimal(10, 2)
  depositPercentage  Int?
  bankAccountInfo    String?
  depositExpiryHours Int      @default(2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courts            Court[]
  reservations      Reservation[]
  cashSessions      CashSession[]
  schedules         ComplexSchedule[]
  staff             User[]            @relation("StaffMembers")
  products          Product[]
  categories        Category[]
  suppliers         Supplier[]
  events            Event[]
  expenses          Expense[]
  tournaments       Tournament[]
  tournamentMatches TournamentMatch[]
}

model ComplexSchedule {
  id          String  @id @default(cuid())
  complexId   String
  complex     Complex @relation(fields: [complexId], references: [id], onDelete: Cascade)
  dayOfWeek   Int // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  openingTime String  @default("08:00")
  closingTime String  @default("23:00")
  isActive    Boolean @default(true)

  @@unique([complexId, dayOfWeek])
}

model Court {
  id                 String  @id @default(cuid())
  complexId          String
  complex            Complex @relation(fields: [complexId], references: [id], onDelete: Cascade)
  name               String
  sportType          String  @default("futbol") // futbol, padel, tenis
  dayRate            Decimal @db.Decimal(10, 2)
  nightRate          Decimal @db.Decimal(10, 2)
  nightRateStartTime String  @default("19:00") // When night rate kicks in
  isActive           Boolean @default(true)
  displayOrder       Int     @default(0)

  // Linked Courts: parent/child relationship
  parentCourtId String?
  parentCourt   Court?  @relation("LinkedCourts", fields: [parentCourtId], references: [id])
  childCourts   Court[] @relation("LinkedCourts")

  reservations     Reservation[]
  tournamentMatches TournamentMatch[]
}

// ============================================
// RESERVATIONS
// ============================================

model Reservation {
  id        String  @id @default(cuid())
  tenantId  String
  complexId String
  complex   Complex @relation(fields: [complexId], references: [id])
  courtId   String
  court     Court   @relation(fields: [courtId], references: [id])
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  // Customer info (for walk-ins or web bookings)
  customerName  String
  customerPhone String?
  customerEmail String?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Time
  date      DateTime @db.Date
  startTime DateTime @db.Timestamptz
  endTime   DateTime @db.Timestamptz

  // Status & Source
  status          String @default("pending") // pending, pending_deposit, confirmed, in_game, finished, paid, cancelled
  reservationType String @default("casual") // casual, fixed, tournament, school, event
  source          String @default("backoffice") // web, backoffice

  // Financials
  courtAmount          Decimal @default(0) @db.Decimal(10, 2)
  consumptionAmount    Decimal @default(0) @db.Decimal(10, 2)
  discount             Decimal @default(0) @db.Decimal(10, 2)
  totalAmount          Decimal @default(0) @db.Decimal(10, 2)
  depositAmount        Decimal @default(0) @db.Decimal(10, 2)
  paidAmount           Decimal @default(0) @db.Decimal(10, 2)
  activeForConsumption Boolean @default(false)

  // Payment
  paymentMethod  String? // cash, card, transfer, mixed
  paymentDetails Json? // For mixed payments: { cash: 5000, card: 3000 }

  // Recurrence
  isRecurring         Boolean @default(false)
  parentReservationId String?

  // Event (all courts)
  isEvent Boolean @default(false)

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales            Sale[]
  payments          Payment[]
  tournamentMatches TournamentMatch[]
  discounts         ReservationDiscount[]

  @@index([complexId, date])
  @@index([courtId, date])
  @@index([status])
  @@index([customerId])
}

model ReservationDiscount {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  description   String
  amount        Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())

  @@index([reservationId])
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name  String
  phone String? @unique
  email String? @unique

  balance Decimal @default(0) @db.Decimal(10, 2)
  defaultDiscount Decimal? @db.Decimal(10, 2)
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]
  payments     Payment[]

  @@index([tenantId])
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id            String       @id @default(cuid())
  tenantId      String
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  eventId       String?
  event         Event?       @relation(fields: [eventId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String // cash, card, transfer
  concept       String   @default("court") // court, consumption, deposit, balance, event
  notes         String?
  createdAt     DateTime @default(now())

  @@index([reservationId])
  @@index([customerId])
  @@index([eventId])
}

// ============================================
// POS & INVENTORY
// ============================================

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  complexId String?
  complex   Complex? @relation(fields: [complexId], references: [id])
  name      String
  contact   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  complexId String?
  complex   Complex? @relation(fields: [complexId], references: [id])
  name      String
  icon      String? // lucide icon name
  isActive  Boolean  @default(true)

  products Product[]
}

model Product {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  complexId   String?
  complex     Complex?  @relation(fields: [complexId], references: [id])
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  name        String
  description String?
  costPrice   Decimal   @db.Decimal(10, 2)
  salePrice   Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0)
  minStock    Int       @default(5)
  trackStock  Boolean   @default(true)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  saleItems SaleItem[]
}

model Sale {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  eventId       String?
  event         Event?       @relation(fields: [eventId], references: [id])
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])

  invoiceNumber      String? @unique // V{YYYYMMDD}-{XXXX}
  subtotal           Decimal @db.Decimal(10, 2)
  total              Decimal @db.Decimal(10, 2)
  status             String  @default("completed") // on_tab, completed, cancelled
  paymentMethod      String? // cash, card, transfer, mixed
  paymentDetails     Json? // For mixed: { cash: 2000, card: 1500 }
  isStaffConsumption Boolean @default(false)

  items     SaleItem[]
  createdAt DateTime   @default(now())

  @@index([tenantId, createdAt])
  @@index([cashSessionId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
}

// ============================================
// CASH MANAGEMENT
// ============================================

model CashSession {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  complexId String
  complex   Complex @relation(fields: [complexId], references: [id])

  openedById String
  openedBy   User    @relation("OpenedBy", fields: [openedById], references: [id])
  closedById String?
  closedBy   User?   @relation("ClosedBy", fields: [closedById], references: [id])

  openingDate    DateTime  @default(now())
  closingDate    DateTime?
  openingBalance Decimal   @db.Decimal(10, 2)
  closingBalance Decimal?  @db.Decimal(10, 2)

  // Calculated at close
  expectedBalance Decimal? @db.Decimal(10, 2)
  cashTotal       Decimal? @db.Decimal(10, 2)
  cardTotal       Decimal? @db.Decimal(10, 2)
  transferTotal   Decimal? @db.Decimal(10, 2)
  difference      Decimal? @db.Decimal(10, 2)

  status String  @default("open") // open, closed
  notes  String?

  sales    Sale[]
  payments Payment[]
  expenses Expense[]

  @@index([tenantId, status])
}

// ============================================
// EVENTS
// ============================================

model Event {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  complexId   String
  complex     Complex  @relation(fields: [complexId], references: [id])
  name        String
  description String?
  date        DateTime @db.Date
  startTime   DateTime @db.Timestamptz
  endTime     DateTime @db.Timestamptz
  totalAmount Decimal  @default(0) @db.Decimal(10, 2)
  depositPaid Decimal  @default(0) @db.Decimal(10, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(10, 2)
  status      String   @default("pending") // pending, confirmed, in_progress, completed, cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments Payment[]
  sales    Sale[]

  @@index([complexId, date])
}

// ============================================
// EXPENSES
// ============================================

model ExpenseCategory {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  isActive Boolean @default(true)

  expenses Expense[]

  @@index([tenantId])
}

model Expense {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  complexId     String
  complex       Complex         @relation(fields: [complexId], references: [id])
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount        Decimal         @db.Decimal(10, 2)
  description   String
  date          DateTime        @db.Date
  cashSessionId String?
  cashSession   CashSession?    @relation(fields: [cashSessionId], references: [id])
  createdAt     DateTime        @default(now())

  @@index([complexId, date])
  @@index([tenantId])
}

// ============================================
// TOURNAMENTS
// ============================================

model Tournament {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  complexId      String
  complex        Complex   @relation(fields: [complexId], references: [id])
  name           String
  sportType      String    @default("futbol")
  status         String    @default("registration") // registration, in_progress, finished
  startDate      DateTime? @db.Date
  endDate        DateTime? @db.Date
  maxTeams       Int       @default(16)
  inscriptionFee Decimal?  @db.Decimal(10, 2)
  rules          String?
  isPublic       Boolean   @default(true)
  publicSlug     String?   @unique // URL pública: /torneos/{slug}
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  teams   TournamentTeam[]
  matches TournamentMatch[]

  @@index([complexId])
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  points       Int        @default(0)
  gamesPlayed  Int        @default(0)
  wins         Int        @default(0)
  draws        Int        @default(0)
  losses       Int        @default(0)
  goalsFor     Int        @default(0)
  goalsAgainst Int        @default(0)

  players     TournamentPlayer[]
  homeMatches TournamentMatch[]  @relation("HomeTeam")
  awayMatches TournamentMatch[]  @relation("AwayTeam")
}

model TournamentPlayer {
  id          String         @id @default(cuid())
  teamId      String
  team        TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  goals       Int            @default(0)
  yellowCards Int            @default(0)
  redCards    Int            @default(0)
}

model TournamentMatch {
  id            String          @id @default(cuid())
  tournamentId  String
  tournament    Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matchDay      Int // fecha/jornada
  homeTeamId    String
  homeTeam      TournamentTeam  @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId    String
  awayTeam      TournamentTeam  @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeGoals     Int?
  awayGoals     Int?
  date          DateTime?       @db.Date
  time          String?
  status        String          @default("scheduled") // scheduled, played, cancelled
  complexId     String?
  complex       Complex?        @relation(fields: [complexId], references: [id])
  courtId       String?
  court         Court?          @relation(fields: [courtId], references: [id])
  reservationId String?
  reservation   Reservation?    @relation(fields: [reservationId], references: [id])
  playerStats   Json?
  notes         String?
}
